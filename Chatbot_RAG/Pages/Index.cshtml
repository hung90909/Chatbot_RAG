              </div>
            </div>

            <div class="agent-panel">
              <div class="agent-header">
                <i class="fas fa-database"></i>
                <span>SQL Agent</span>
                <div class="agent-status" id="sqlStatus"></div>
              </div>
              <div class="agent-content" id="sqlContent">
                <p style="color: var(--text-muted); font-size: 12px;">Chưa có truy vấn</p>
              </div>
            </div>

            <div class="agent-panel">
              <div class="agent-header">
                <i class="fas fa-tools"></i>
                <span>Tool Agent</span>
                <div class="agent-status" id="toolStatus"></div>
              </div>
              <div class="agent-content" id="toolContent">
                <p style="color: var(--text-muted); font-size: 12px;">Chưa có công cụ được gọi</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Asset Management Module -->
      <div class="module" id="assetsModule">
        <div class="asset-grid">
          <h3 style="margin-bottom: 20px; font-size: 20px;">Danh sách tài sản công</h3>
          <div class="asset-card">
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
              <strong>Máy tính để bàn HP</strong>
              <span style="color: var(--success); font-size: 12px;">Đang sử dụng</span>
            </div>
            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">Mã TS: MT-2024-001 | Đơn vị: Phòng CNTT</p>
            <p style="font-size: 13px;">Nguyên giá: 25,000,000 VNĐ | Giá trị còn lại: 18,750,000 VNĐ</p>
          </div>
          <div class="asset-card">
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
              <strong>Xe ô tô Toyota Camry</strong>
              <span style="color: var(--warning); font-size: 12px;">Cần bảo trì</span>
            </div>
            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">Mã TS: XE-2020-005 | Đơn vị: Văn phòng</p>
            <p style="font-size: 13px;">Nguyên giá: 1,200,000,000 VNĐ | Giá trị còn lại: 720,000,000 VNĐ</p>
          </div>
        </div>
      </div>

      <!-- Upload Module -->
      <div class="module" id="uploadModule">
        <div class="upload-area">
          <h3 style="margin-bottom: 24px; font-size: 20px;">Upload tài liệu PDF</h3>
          <div class="upload-zone">
            <i class="fas fa-cloud-upload-alt"></i>
            <h4 style="margin-bottom: 8px;">Kéo thả file PDF vào đây</h4>
            <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 16px;">hoặc click để chọn file</p>
            <button class="btn-primary" style="max-width: 200px; margin: 0 auto;">Chọn file PDF</button>
          </div>
          <p style="margin-top: 20px; font-size: 12px; color: var(--text-muted);">
            Hỗ trợ: Thông tư, Nghị định, Quyết định, Báo cáo tài sản. Dung lượng tối đa 50MB
          </p>
        </div>
      </div>

      <!-- Login Module -->
      <div class="module" id="loginModule">
        <div class="login-form">
          <h3 style="margin-bottom: 24px; font-size: 20px; text-align: center;">Đăng nhập hệ thống</h3>
          <div class="form-group">
            <label>Tên đăng nhập</label>
            <input type="text" placeholder="Nhập tên đăng nhập">
          </div>
          <div class="form-group">
            <label>Mật khẩu</label>
            <input type="password" placeholder="Nhập mật khẩu">
          </div>
          <div class="form-group">
            <label>Đơn vị</label>
            <select>
              <option>Sở Tài chính</option>
              <option>UBND Tỉnh</option>
              <option>Sở Kế hoạch & Đầu tư</option>
            </select>
          </div>
          <button class="btn-primary">Đăng nhập</button>
        </div>
      </div>
    </div>
  </div>
</div>
